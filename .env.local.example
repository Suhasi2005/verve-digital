# Copy this file to ".env.local" and fill in real values.
# (.env.local is git-ignored, so your keys stay private.)

# --- Contact form email (Resend) ---
# 1. Sign up free at https://resend.com and create an API key.
# 2. Paste it below.
RESEND_API_KEY=

# Where contact-form submissions are emailed (your inbox).
CONTACT_TO_EMAIL=youremail@example.com

# Optional: only needed once you verify your own domain in Resend.
# Until then, leave blank and emails send from onboarding@resend.dev.
# CONTACT_FROM_EMAIL=hello@yourdomain.com

# --- Analytics (optional) ---
# Add your Google Analytics 4 measurement ID to enable analytics.
# Leave blank and no analytics scripts load at all.
NEXT_PUBLIC_GA_ID=
